# Files excluded from `git archive` (and therefore from release zips)
# Server owners don't need any of this.

.github/             export-ignore
.gitattributes       export-ignore
.gitignore           export-ignore
.editorconfig        export-ignore
.luacheckrc          export-ignore
CONTRIBUTING.md      export-ignore
SECURITY.md          export-ignore
docs/                export-ignore

# Normalize line endings to LF on checkout. FiveM is happier this way.
* text=auto eol=lf
*.lua text eol=lf
*.md  text eol=lf
*.yml text eol=lf
